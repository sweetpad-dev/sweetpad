# Corpus clones — recreated by scripts/01_clone_corpus.py
corpus/*/
!corpus/manifest.json

# Build / IDE state
DerivedData/
.derived/
*.xcuserstate
xcuserdata/

# In-tree xcodebuild output from building a fixture without -derivedDataPath. The
# BSP test harness is hermetic (it builds a temp copy with throwaway derived
# data), so anything under a fixture's build/ is stray and safe to ignore.
fixtures/**/build/
# The corpus-completion harness writes a transient buildServer.json into a
# fixture's project dir and removes it; ignore any left by an interrupted run.
fixtures/**/buildServer.json

# Transient Xcodes installed by scripts/13_capture_version.py (one `rm -rf` cleans up)
.xcodes/

# Python
.venv/
__pycache__/
*.pyc

# macOS
.DS_Store

# Local-only state for build runner
.cache/

# Rust
/target

# Personal IDE/agent state
.claude/

# Xcode index store — large, IDE-internal, not used as oracle data
**/index-store.tgz

# Compressed activity log — redundant with xcactivitylog.parsed.json
**/xcactivitylog.gz

# napi node addon (generated build outputs)
/node_modules/
/*.node
/index.js
/index.d.ts

# Native `sweetpad` CLI staged for the extension bundle (build:cli:*)
/sweetpad-cli
